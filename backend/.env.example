# Server
PORT=5000

# PostgreSQL Database
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password
DB_NAME=your_db_name
DB_HOST=your_db_host
DB_PORT=5432

# JWT
JWT_SECRET=your_jwt_secret_key
JWT_SECRET_PUBLIC=your_jwt_public_key
JWT_BOOKING_SECRET=your_jwt_booking_secret

# AWS
AWS_REGION=ap-south-1
SQS_BOOKING_URL=https://sqs.your-region.amazonaws.com/your-account-id/your-booking-queue
SQS_EMAIL_QUEUE_URL=https://sqs.your-region.amazonaws.com/your-account-id/your-email-queue

# Discord Logging (optional)
DISCORD_ERROR_WEBHOOK_URL=https://discord.com/api/webhooks/your-error-webhook
DISCORD_INFO_WEBHOOK_URL=https://discord.com/api/webhooks/your-info-webhook
